# Cloud provider (aws or azure)
DB_PROVIDER=aws

# AWS configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB (leave empty for AWS, set for local development)
DYNAMODB_ENDPOINT=http://localhost:8000

# Table names
LOCATIONS_TABLE=file_locations
MOVEMENTS_TABLE=file_movements
READERS_TABLE=readers
TAGS_TABLE=tags

# RSSI Resolver
RSSI_WINDOW_SECONDS=10
RSSI_CONFIDENCE_THRESHOLD=6

# MQTT
MQTT_TOPIC_PREFIX=courthouse/rfid

# API
CORS_ORIGIN=*
STAGE=dev
